# URL de connexion PostgreSQL fournie par Supabase (avec extension pgvector activée)
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

# Cle API Groq (LLM cloud)
GROQ_API_KEY=

# Fournisseur LLM actif : groq | ollama
LLM_PROVIDER=groq

# Modele utilise si LLM_PROVIDER=ollama (doit etre pull en local au prealable)
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
